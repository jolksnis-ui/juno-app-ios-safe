# JIRA Configuration
# Create your own .env file with these values filled in
# Generate API token at: https://id.atlassian.com/manage-profile/security/api-tokens

JIRA_HOST=yourcompany.atlassian.net
JIRA_EMAIL=your.email@company.com
JIRA_API_TOKEN=your_api_token_here

# Example:
# JIRA_HOST=acmecorp.atlassian.net
# JIRA_EMAIL=john.doe@acmecorp.com
# JIRA_API_TOKEN=ATATT3xFfGF0...

# Claude API Configuration
EXPO_PUBLIC_CLAUDE_API_KEY=""
EXPO_PUBLIC_CLAUDE_MODEL="claude-3-5-sonnet-20241022"
EXPO_PUBLIC_CLAUDE_MAX_TOKENS=1024
EXPO_PUBLIC_ENABLE_CLAUDE_STREAMING=false

# Instructions:
# 1. Copy this file to .env
# 2. Replace the empty CLAUDE_API_KEY with your actual Claude API key
# 3. Adjust Claude settings if needed (optional)
# 4. Make sure .env is added to your .gitignore file to keep your API key secure
#
# To get a Claude API key:
# 1. Go to https://console.anthropic.com/
# 2. Sign up or log in to your Anthropic account
# 3. Create a new API key
# 4. Copy the key and paste it here
#
# Claude Settings Explained:
# - CLAUDE_API_KEY: Your Anthropic Claude API key (required for AI responses)
# - CLAUDE_MODEL: Claude model to use (default: claude-3-5-sonnet-20241022)
# - CLAUDE_MAX_TOKENS: Maximum tokens per response (default: 1024)
# - ENABLE_CLAUDE_STREAMING: Enable streaming responses (default: false)
#
# Available Claude Models:
# - claude-3-5-sonnet-20241022 (recommended - best balance of speed and quality)
# - claude-3-opus-20240229 (highest quality, slower)
# - claude-3-haiku-20240307 (fastest, lower cost)
#
# Note: The chatbot works without an API key using intelligent mock responses
